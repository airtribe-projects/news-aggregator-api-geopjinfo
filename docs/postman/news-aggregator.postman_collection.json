        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const token = body.token || body.data?.token;",
                  "const user = body.user || body.data?.user;",
                  "pm.test('Login returns a token', function () {",
                  "  pm.expect(token).to.be.a('string').and.not.empty;",
                  "});",
                  "if (token) pm.environment.set('jwtToken', token);",
                  "if (user?.id) pm.environment.set('userId', user.id);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "login"
              ]
            },
            "description": "Authenticates a user and stores the returned JWT in the active environment."
          },
          "response": []
        }
      ]
