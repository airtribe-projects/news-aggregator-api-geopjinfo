    {
      "name": "News",
      "item": [
        {
          "name": "Get Top Headlines",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const articles = body.news || body.data?.news || [];",
                  "pm.test('News response returns an array', function () {",
                  "  pm.expect(articles).to.be.an('array');",
                  "});",
                  "if (Array.isArray(articles) && articles.length > 0) {",
                  "  const article = articles[0];",
                  "  const articleId = article.articleId || article.url;",
                  "  if (articleId) {",
                  "    pm.environment.set('articleId', articleId);",
                  "    pm.environment.set('encodedArticleId', encodeURIComponent(articleId));",
                  "  }",
                  "  if (article.title) pm.environment.set('articleTitle', article.title);",
                  "  if (article.url) pm.environment.set('articleUrl', article.url);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/news",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "news"
              ]
            },
            "description": "Gets personalized top headlines and caches the first article into environment variables for subsequent requests."
          },
          "response": []
        },
        {
          "name": "Get Read Articles",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/news/read",
              "host": [
